{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zentto Web3",
  "version": "0.1.0",
  "identifier": "net.zentto.web3",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3100",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run export"
  },
  "app": {
    "windows": [
      {
        "title": "Zentto Web3",
        "width": 1200,
        "height": 800,
        "minWidth": 375,
        "minHeight": 667,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
